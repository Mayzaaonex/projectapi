{
  "version": 2,
  "functions": {
    "api/track.js": {
      "memory": 128,
      "maxDuration": 10
    },
    "api/stats.js": {
      "memory": 128,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/track", "destination": "/api/track" },
    { "source": "/api/stats", "destination": "/api/stats" }
  ],
  "routes": [
    { "src": "/public/(.*)", "dest": "/public/$1" },
    { "src": "/maker/brat", "dest": "/maker/brat.html" },
    { "src": "/maker", "dest": "/maker/index.html" },
    { "src": "/maker/", "dest": "/maker/index.html" },
    { "src": "/downloader", "dest": "/downloader/index.html" },
    { "src": "/downloader/", "dest": "/downloader/index.html" },
    { "src": "/", "dest": "/index.html" }
  ]
}