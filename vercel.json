{
  "version": 2,
  "builds": [
    { "src": "**/*.html", "use": "@vercel/static" },
    { "src": "public/**/*", "use": "@vercel/static" },
    { "src": "api/**/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/public/(.*)", "dest": "/public/$1" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/maker/brat", "dest": "/maker/brat.html" },
    { "src": "/maker", "dest": "/maker/index.html" },
    { "src": "/maker/", "dest": "/maker/index.html" },
    { "src": "/downloader", "dest": "/downloader/index.html" },
    { "src": "/downloader/", "dest": "/downloader/index.html" },
    { "src": "/", "dest": "/index.html" }
  ]
}